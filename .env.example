# Copy this file to .env and fill in your values
# .env is gitignored — never commit real credentials

# ── ProtonVPN WireGuard ──────────────────────────────────────────────────────
# Get from: https://account.proton.me/u/0/vpn/WireGuard → Create config
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=         # e.g. 10.2.0.2/32
VPN_ENDPOINT_IP=             # e.g. 185.159.157.5
VPN_ENDPOINT_PORT=51820
WIREGUARD_PUBLIC_KEY=

# ── General ──────────────────────────────────────────────────────────────────
TZ=America/New_York          # https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
PUID=1000
PGID=1000

# ── Pi-hole ───────────────────────────────────────────────────────────────────
PIHOLE_PASSWORD=             # Admin UI password for Pi-hole

# ── *arr API keys (Decluttarr + n8n workflows) ────────────────────────────────
RADARR_KEY=                  # Radarr → Settings → General → API Key
SONARR_KEY=                  # Sonarr → Settings → General → API Key
PROWLARR_KEY=                # Prowlarr → Settings → General → API Key
